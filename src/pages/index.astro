---
import Base from '../layouts/Base.astro';
import { topics, products, site } from '../config/site';

const highlights = topics.slice(0, 4);
const framework = [
  ['Structure', 'Atoms, phases, defects, and interfaces'],
  ['Processing', 'Synthesis, history, and transformation'],
  ['Properties', 'Mechanical, optical, thermal, and electronic response'],
  ['Performance', 'Function, reliability, and operating context'],
];
---

<Base
  title="BN Material"
  description="Advanced materials research, scientific software, computational modeling, and reproducible engineering knowledge."
>
  <section class="home-ref">
    <canvas id="material-field" aria-hidden="true"></canvas>
    <div class="home-grid" aria-hidden="true"></div>

    <div class="shell hero-console">
      <div class="hero-message" data-reveal>
        <span class="hero-eyebrow">Advancing materials. Empowering discovery.</span>
        <h1>Materials science<br />for a better future.</h1>
        <p>
          Connecting materials research, computational modeling, advanced characterization, and
          focused scientific software.
        </p>
        <div class="actions">
          <a class="button" href="/research"><span>Explore research</span><b>→</b></a>
          <a class="button ghost" href="/software"><span>Our software</span><b>→</b></a>
        </div>
      </div>

      <div class="molecule-stage" aria-label="Conceptual animated crystalline material model">
        <div class="model-label model-label-top"><span>CRYSTAL FIELD</span><b>BN—MSE / 01</b></div>
        <div class="molecule" aria-hidden="true">
          <div class="core"><span>BN</span></div>
          <i class="orbit orbit-a"></i><i class="orbit orbit-b"></i><i class="orbit orbit-c"></i>
          {
            Array.from({ length: 12 }).map((_, index) => (
              <i class="atom" style={`--atom:${index}`} />
            ))
          }
        </div>
        <div class="model-floor" aria-hidden="true"><i></i><i></i><i></i><i></i></div>
        <div class="model-label model-label-bottom">
          <span>STRUCTURE / RESPONSE</span><b>LIVE MODEL</b>
        </div>
      </div>

      <aside class="highlights-panel" data-reveal>
        <div class="panel-title"><span>Research highlights</span><i></i></div>
        <div class="highlight-list">
          {
            highlights.map((topic, index) => (
              <a href={`/topics/${topic.slug}`} class={`highlight h-${index + 1}`}>
                <span class="highlight-mark">0{index + 1}</span>
                <span>
                  <strong>{topic.title}</strong>
                  <small>{topic.summary}</small>
                </span>
                <b>↗</b>
              </a>
            ))
          }
        </div>
        <a class="panel-link" href="/topics"><span>View all topic domains</span><b>→</b></a>
      </aside>
    </div>

    <div class="shell software-deck" data-reveal>
      <div class="deck-heading">
        <span>Scientific software</span><i></i><small>Purpose-built analysis environments</small>
      </div>
      <div class="software-card-grid">
        {
          products.map((product, index) => (
            <a
              href={`/software/${product.slug}`}
              class:list={['software-card', `software-card-${product.accent}`]}
              data-tilt
            >
              <div class="software-icon">
                <span>0{index + 1}</span>
              </div>
              <div class="software-copy">
                <small>{product.status}</small>
                <h2>{product.name}</h2>
                <p>{product.summary}</p>
                <span class="learn-link">Explore workspace →</span>
              </div>
              <div class:list={['software-mini', `software-mini-${index + 1}`]} aria-hidden="true">
                <>
                  <i />
                  <i />
                  <i />
                </>
                {index === 1 && Array.from({ length: 9 }).map((_, n) => <b style={`--n:${n}`} />)}
              </div>
            </a>
          ))
        }
      </div>
    </div>

    <div class="shell proof-row" data-reveal>
      <div class="proof-metrics">
        <div><strong>06</strong><span>Research topic<br />domains</span></div>
        <div><strong>03</strong><span>Scientific software<br />workspaces</span></div>
        <div><strong>04</strong><span>Materials engineering<br />stages</span></div>
        <div><strong>01</strong><span>Independent<br />platform</span></div>
      </div>
      <a class="spectra-feature" href="/software/bn-spectra-studio-pro" data-tilt>
        <div>
          <small>Featured software / private beta</small>
          <h2>BN Spectra Studio Pro</h2>
          <p>A focused workspace for experimental spectra and publication-oriented figures.</p>
          <span>View the product →</span>
        </div>
        <div class="product-box" aria-hidden="true">
          <i></i><b>BN</b><span>SPECTRA<br />STUDIO<br />PRO</span>
        </div>
        <div class="feature-wave" aria-hidden="true"><i></i><i></i><i></i></div>
      </a>
    </div>
  </section>

  <section class="research-stage section-pad">
    <div class="shell research-head">
      <div class="research-copy" data-reveal>
        <span class="section-index">01 / Research continuum</span>
        <h2>One platform.<br /><em>Every relevant scale.</em></h2>
      </div>
      <p data-reveal>
        BN Material links experimental evidence, computation, characterization, and scientific
        communication into a traceable way of working.
      </p>
    </div>
    <div class="shell research-domain-grid">
      {
        topics.map((topic, index) => (
          <a href={`/topics/${topic.slug}`} class={`domain domain-${index + 1}`} data-reveal>
            <span>0{index + 1}</span>
            <div class="domain-glyph" aria-hidden="true">
              <>
                <i />
                <i />
                <i />
              </>
            </div>
            <h3>{topic.title}</h3>
            <p>{topic.summary}</p>
            <b>Explore →</b>
          </a>
        ))
      }
    </div>
  </section>

  <section class="framework-stage section-pad">
    <div class="shell framework-title" data-reveal>
      <span class="section-index">02 / Materials engineering logic</span>
      <h2>From atomic arrangement<br />to real-world performance.</h2>
    </div>
    <div class="shell framework-flow">
      {
        framework.map(([label, copy], index) => (
          <div class="flow-node" data-reveal>
            <div class="flow-orbit">
              <>
                <span>0{index + 1}</span>
                <i />
                <i />
                <i />
              </>
            </div>
            <h3>{label}</h3>
            <p>{copy}</p>
            {index < framework.length - 1 && <b class="flow-arrow">→</b>}
          </div>
        ))
      }
    </div>
  </section>

  <section class="knowledge-stage section-pad">
    <div class="shell knowledge-layout">
      <article class="knowledge-lead" data-reveal>
        <span class="section-index">03 / Reproducible knowledge</span>
        <h2>Evidence before volume.</h2>
        <p>
          Publications, benchmarks, and resources are organized around verified records, visible
          assumptions, and reproducible methods.
        </p>
        <div class="actions">
          <a class="button" href="/publications"><span>Publications</span><b>→</b></a>
          <a class="button ghost" href="/resources"><span>Resources</span><b>→</b></a>
        </div>
      </article>
      <a class="knowledge-card knowledge-benchmark" href="/benchmarks" data-tilt data-reveal>
        <small>Benchmarks</small><div aria-hidden="true">
          {Array.from({ length: 7 }).map(() => <i />)}
        </div>
        <h3>Transparent comparisons.</h3><span>Review the catalogue →</span>
      </a>
      <a class="knowledge-card knowledge-academy" href="/academy" data-tilt data-reveal>
        <small>Academy</small><div class="lambda" aria-hidden="true">λ</div>
        <h3>Learn the workflow, not only the result.</h3><span>Enter the academy →</span>
      </a>
    </div>
  </section>

  <section class="independent-stage section-pad">
    <div class="shell independent-layout">
      <div class="independent-mark" aria-hidden="true" data-reveal><span>BN</span><i></i></div>
      <div data-reveal>
        <span class="section-index">04 / Independent platform</span>
        <h2>Research depth.<br /><em>Software discipline.</em></h2>
        <p>
          Founded by {site.founder}, affiliated with {site.affiliation}. BN Material is independent
          and is not an official NAST website; affiliation does not imply institutional endorsement.
        </p>
        <a class="text-link" href="/about">About BN Material <span>→</span></a>
      </div>
    </div>
  </section>

  <script is:inline>
    const canvas = document.querySelector('#material-field');
    const molecule = document.querySelector('.molecule');
    const reduce = matchMedia('(prefers-reduced-motion:reduce)').matches;
    if (canvas && !reduce) {
      const ctx = canvas.getContext('2d');
      const points = [];
      const pointer = { x: -999, y: -999 };
      let width = 0;
      let height = 0;
      let raf = 0;
      const resize = () => {
        const density = Math.min(devicePixelRatio, 1.5);
        width = canvas.clientWidth;
        height = canvas.clientHeight;
        canvas.width = width * density;
        canvas.height = height * density;
        ctx.setTransform(density, 0, 0, density, 0, 0);
        points.length = 0;
        const gap = Math.max(70, Math.min(105, width / 16));
        for (let y = -gap; y < height + gap; y += gap * 0.86) {
          for (let x = -gap; x < width + gap; x += gap) {
            points.push({ x: x + ((Math.round(y / gap) % 2) * gap) / 2, y });
          }
        }
      };
      const draw = (time) => {
        ctx.clearRect(0, 0, width, height);
        const visiblePoints = points.map((point, index) => ({
          x: point.x + Math.sin(time / 2400 + index) * 2,
          y: point.y + Math.cos(time / 2100 + index) * 2,
        }));
        for (let index = 0; index < visiblePoints.length; index += 1) {
          const point = visiblePoints[index];
          const distanceToPointer = Math.hypot(pointer.x - point.x, pointer.y - point.y);
          const glow = Math.max(0, 1 - distanceToPointer / 260);
          const right = visiblePoints[index + 1];
          if (right && Math.hypot(point.x - right.x, point.y - right.y) < 120) {
            ctx.strokeStyle = `rgba(71,191,255,${0.035 + glow * 0.16})`;
            ctx.beginPath();
            ctx.moveTo(point.x, point.y);
            ctx.lineTo(right.x, right.y);
            ctx.stroke();
          }
          ctx.fillStyle = `rgba(120,225,255,${0.12 + glow * 0.55})`;
          ctx.beginPath();
          ctx.arc(point.x, point.y, 1 + glow * 1.5, 0, Math.PI * 2);
          ctx.fill();
        }
        raf = requestAnimationFrame(draw);
      };
      canvas.addEventListener('pointermove', (event) => {
        const bounds = canvas.getBoundingClientRect();
        pointer.x = event.clientX - bounds.left;
        pointer.y = event.clientY - bounds.top;
        if (molecule) {
          molecule.style.setProperty('--px', `${(pointer.x / bounds.width - 0.5) * 12}px`);
          molecule.style.setProperty('--py', `${(pointer.y / bounds.height - 0.5) * 10}px`);
        }
      });
      canvas.addEventListener('pointerleave', () => {
        pointer.x = -999;
        pointer.y = -999;
        molecule?.style.setProperty('--px', '0px');
        molecule?.style.setProperty('--py', '0px');
      });
      addEventListener('resize', resize, { passive: true });
      resize();
      raf = requestAnimationFrame(draw);
      document.addEventListener('visibilitychange', () => {
        if (document.hidden) cancelAnimationFrame(raf);
        else raf = requestAnimationFrame(draw);
      });
    }
  </script>
</Base>
