---
import Base from '../../layouts/Base.astro';
import { engineeringScales, topics } from '../../config/site';

export function getStaticPaths() {
  return topics.map((topic, index) => ({ params: { slug: topic.slug }, props: { topic, index } }));
}

const { topic, index } = Astro.props;
const inquiryAreas = [
  [
    'Core scientific questions',
    `How composition, bonding, defects, interfaces, morphology, and environment govern ${topic.shortTitle.toLowerCase()} behavior.`,
  ],
  [
    'Experimental evidence',
    `How synthesis, processing, calibrated characterization, controls, and uncertainty support defensible conclusions in ${topic.shortTitle.toLowerCase()}.`,
  ],
  [
    'Computational interpretation',
    'How electronic-structure calculations, atomistic simulation, continuum models, or data-driven methods can test mechanisms without replacing validation.',
  ],
  [
    'Engineering translation',
    'How performance, reliability, manufacturability, safety, sustainability, and scale-up constrain useful material solutions.',
  ],
];
---

<Base title={topic.title} description={topic.summary}>
  <section class:list={['topic-hero', `accent-${topic.accent}`]}>
    <div class="shell topic-hero-inner">
      <div class="topic-hero-copy" data-reveal>
        <p class="eyebrow">Materials domain / {String(index + 1).padStart(2, '0')}</p>
        <h1>{topic.title}</h1>
        <p>{topic.summary}</p>
      </div>
      <aside class="topic-hero-aside" data-reveal>
        <span>Methods and perspectives</span>
        <strong>{topic.methods.length}</strong>
        <p>{topic.methods.join(' · ')}</p>
      </aside>
    </div>
  </section>

  <section class="topic-detail-section">
    <div class="shell topic-detail-layout">
      <aside class="topic-detail-nav" data-reveal>
        <p class="micro-label">Domain framework</p>
        <h2>Mechanism to application.</h2>
        <p>
          This topic hub is designed to connect scientific fundamentals, evidence, computation,
          process history, performance, and responsible translation.
        </p>
        <a class="text-link" href="/topics">Return to all domains <span>↗</span></a>
      </aside>
      <div class="topic-detail-content">
        {
          inquiryAreas.map(([title, copy], i) => (
            <article data-reveal>
              <span>
                {String(i + 1).padStart(2, '0')} / {topic.shortTitle}
              </span>
              <h3>{title}</h3>
              <p>{copy}</p>
              {i === 1 && (
                <ul>
                  {topic.methods.map((method) => (
                    <li>{method}</li>
                  ))}
                </ul>
              )}
              {i === 3 && (
                <ul>
                  {engineeringScales.map(([scale, description]) => (
                    <li>
                      <strong>{scale}:</strong> {description}
                    </li>
                  ))}
                </ul>
              )}
            </article>
          ))
        }
      </div>
    </div>
  </section>
</Base>
