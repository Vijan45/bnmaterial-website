---
import Base from '../../layouts/Base.astro';
import { products, site } from '../../config/site';
export function getStaticPaths() {
  return products.map((product) => ({ params: { slug: product.slug }, props: { product } }));
}
const { product } = Astro.props;
const ld = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: product.name,
  applicationCategory: 'ScienceApplication',
  operatingSystem: 'Not yet specified',
  description: product.summary,
  author: { '@type': 'Person', name: site.founder },
};
---

<Base title={product.name} description={product.summary}
  ><script type="application/ld+json" set:html={JSON.stringify(ld)} /><section
    class="page-hero container"
  >
    <span class="status">{product.status}</span><p class="eyebrow">{product.category}</p><h1>
      {product.name}
    </h1><p class="lead">{product.summary}</p><div class="actions">
      <a class="button" href="/contact">Request access</a><a
        class="button secondary"
        href="#capabilities">View capabilities</a
      >
    </div>
  </section><section>
    <div class="container">
      <div
        class="product-visual"
        role="img"
        aria-label={`Conceptual ${product.name} product-interface illustration`}
      >
        <div class="curve"></div>
      </div><div class="grid" id="capabilities">
        <article class="card">
          <h2>Current positioning</h2>{
            product.features.length ? (
              <ul>
                {product.features.map((x) => (
                  <li>{x}</li>
                ))}
              </ul>
            ) : (
              <p>
                No executable or source evidence was supplied. The product is therefore described
                only as a developing environment.
              </p>
            )
          }
        </article><article class="card">
          <h2>Development roadmap</h2><ul>{product.planned.map((x) => <li>{x}</li>)}</ul>
        </article><article class="card">
          <h2>Access & licensing</h2><p>
            Access method, platform support, version, and licensing remain configurable until a
            reviewed release is provided.
          </p><a href="/contact">Contact the developer →</a>
        </article>
      </div>
    </div>
  </section></Base
>
