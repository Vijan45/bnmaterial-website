---
import Base from '../layouts/Base.astro';
import { engineeringScales, products, site, topics } from '../config/site';

const capabilities = [
  ['Experimental', 'Synthesis, processing, characterization, and mechanism-aware validation.'],
  ['Computational', 'Electronic structure, molecular simulation, and model-based interpretation.'],
  ['Analytical', 'Reproducible data systems, quantitative analysis, and scientific visualization.'],
  [
    'Translational',
    'Engineering decisions that connect performance, reliability, scale, and deployment.',
  ],
];
---

<Base
  title="BN Material"
  description="A broad materials-engineering platform spanning crystal engineering, molecular dynamics, semiconductors, solar cells, biomaterials, ceramics, polymers, nanomaterials, metallurgy, catalysis, characterization, and processing."
>
  <section class="hero">
    <div class="hero-glow hero-glow-a" aria-hidden="true"></div>
    <div class="hero-glow hero-glow-b" aria-hidden="true"></div>
    <div class="shell hero-layout">
      <div class="hero-copy" data-reveal>
        <p class="hero-kicker"><i></i> Materials science · computation · software</p>
        <h1>
          Materials engineered
          <span>for what comes next.</span>
        </h1>
        <p class="hero-lead">
          BN Material connects mechanisms, experiments, computation, characterization, and
          purpose-built software across the full materials-engineering landscape.
        </p>
        <div class="hero-actions">
          <a class="button button-primary" href="/topics"
            ><span>Explore the materials landscape</span><b>↗</b></a
          >
          <a class="button button-outline" href="/software"
            ><span>Discover scientific software</span><b>→</b></a
          >
        </div>
        <div class="hero-proof" aria-label="Platform principles">
          <span>Atomic → system</span>
          <span>Experiment + computation</span>
          <span>Evidence-led</span>
        </div>
      </div>

      <div class="hero-spectrum" data-reveal aria-label="Conceptual multiscale materials field">
        <div class="spectrum-topline">
          <span>Material response field</span>
          <small>Conceptual visualization</small>
        </div>
        <svg viewBox="0 0 700 620" role="img" aria-labelledby="spectrum-title spectrum-desc">
          <title id="spectrum-title">Connected materials engineering scales</title>
          <desc id="spectrum-desc">
            Abstract spectral curves connect electronic, atomic, microstructural, and system scales.
            The illustration is conceptual and is not measured data.
          </desc>
          <defs>
            <linearGradient id="spectrum-a" x1="0" y1="0" x2="1" y2="1">
              <stop offset="0" stop-color="#00f5ff"></stop>
              <stop offset=".48" stop-color="#7d6dff"></stop>
              <stop offset="1" stop-color="#ff4fd8"></stop>
            </linearGradient>
            <linearGradient id="spectrum-b" x1="0" y1="1" x2="1" y2="0">
              <stop offset="0" stop-color="#00f5ff" stop-opacity=".05"></stop>
              <stop offset=".5" stop-color="#7d6dff" stop-opacity=".68"></stop>
              <stop offset="1" stop-color="#ffd84d" stop-opacity=".16"></stop>
            </linearGradient>
            <radialGradient id="spectrum-core">
              <stop offset="0" stop-color="#fff" stop-opacity=".96"></stop>
              <stop offset=".18" stop-color="#00f5ff" stop-opacity=".8"></stop>
              <stop offset=".54" stop-color="#7d6dff" stop-opacity=".28"></stop>
              <stop offset="1" stop-color="#7d6dff" stop-opacity="0"></stop>
            </radialGradient>
          </defs>
          <g class="spectrum-grid">
            <path d="M54 92H646M54 202H646M54 312H646M54 422H646M54 532H646"></path>
            <path d="M95 55V565M220 55V565M345 55V565M470 55V565M595 55V565"></path>
          </g>
          <circle class="spectrum-halo spectrum-halo-wide" cx="354" cy="307" r="202"></circle>
          <circle class="spectrum-halo spectrum-halo-mid" cx="354" cy="307" r="134"></circle>
          <circle class="spectrum-core" cx="354" cy="307" r="116" fill="url(#spectrum-core)"
          ></circle>
          <g class="spectrum-curves">
            <path class="curve curve-a" d="M48 415C151 134 247 541 349 278S548 138 660 334"></path>
            <path class="curve curve-b" d="M44 344C172 502 230 105 361 348S543 498 659 196"></path>
            <path class="curve curve-c" d="M42 250C159 77 231 457 357 265S545 197 662 421"></path>
            <path class="curve curve-d" d="M52 500C181 354 223 158 357 221S535 528 652 119"></path>
          </g>
          <g class="spectrum-points">
            <g transform="translate(116 395)">
              <circle r="7"></circle><text x="0" y="26">ELECTRONIC</text>
            </g>
            <g transform="translate(276 179)">
              <circle r="7"></circle><text x="0" y="-18">ATOMIC</text>
            </g>
            <g transform="translate(477 395)">
              <circle r="7"></circle><text x="0" y="27">MICROSTRUCTURE</text>
            </g>
            <g transform="translate(593 206)">
              <circle r="7"></circle><text x="0" y="-18">SYSTEM</text>
            </g>
          </g>
        </svg>
        <div class="spectrum-footer">
          <span>Composition</span><i></i><span>Structure</span><i></i><span>Process</span><i
          ></i><span>Performance</span>
        </div>
      </div>
    </div>
    <div class="shell hero-rail" aria-label="BN Material scope">
      <span>01 <b>Research</b></span>
      <span>02 <b>Characterization</b></span>
      <span>03 <b>Computation</b></span>
      <span>04 <b>Scientific software</b></span>
    </div>
  </section>

  <section class="intro-section section-space">
    <div class="shell intro-layout">
      <div data-reveal>
        <p class="micro-label">A connected materials platform</p>
        <h2>
          One field.<br />
          <span>Every relevant scale.</span>
        </h2>
      </div>
      <div class="intro-copy" data-reveal>
        <p class="intro-lead">
          Useful materials knowledge does not live inside a single instrument, simulation, or
          discipline.
        </p>
        <p>
          BN Material is structured around the relationships between composition, structure,
          processing, properties, and performance. Experimental evidence, computational
          interpretation, and software practice remain connected without blurring their boundaries.
        </p>
        <a class="text-link" href="/research">Read the research framework <span>↗</span></a>
      </div>
    </div>
    <div class="shell discipline-rail" data-reveal>
      <span>Materials research</span>
      <span>Computational modeling</span>
      <span>Scientific data systems</span>
      <span>Engineering translation</span>
    </div>
  </section>

  <section class="topics-section section-space">
    <div class="shell section-heading" data-reveal>
      <div>
        <p class="micro-label">01 / Materials landscape</p>
        <h2>Twelve topics.<br /><span>One connected framework.</span></h2>
      </div>
      <p>
        Explore the mechanisms, material classes, analytical methods, and engineering decisions that
        shape modern materials science.
      </p>
    </div>
    <div class="shell topic-directory">
      {
        topics.map((topic, index) => (
          <a
            class:list={['topic-row', `accent-${topic.accent}`]}
            href={`/topics/${topic.slug}`}
            data-reveal
          >
            <span class="topic-number">{String(index + 1).padStart(2, '0')}</span>
            <div>
              <h3>{topic.shortTitle}</h3>
              <p>{topic.methods.slice(0, 3).join(' · ')}</p>
            </div>
            <b aria-hidden="true">↗</b>
          </a>
        ))
      }
    </div>
    <div class="shell section-end" data-reveal>
      <a class="text-link" href="/topics">Explore all materials topics <span>↗</span></a>
    </div>
  </section>

  <section class="scale-section section-space">
    <div class="shell scale-layout">
      <div class="scale-intro" data-reveal>
        <p class="micro-label">02 / Multiscale thinking</p>
        <h2>From bonding<br />to deployment.</h2>
        <p>
          Materials performance emerges through connected scales. Each level informs the next
          without pretending that one model can explain the whole system.
        </p>
        <a class="text-link" href="/research">Explore the research logic <span>↗</span></a>
      </div>
      <div class="scale-stack" data-reveal>
        {
          engineeringScales.map(([scale, description], index) => (
            <article style={`--scale-index:${index}`}>
              <span>{String(index + 1).padStart(2, '0')}</span>
              <div>
                <h3>{scale}</h3>
                <p>{description}</p>
              </div>
              <i />
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="software-section section-space">
    <div class="shell software-heading" data-reveal>
      <div>
        <p class="micro-label">03 / Scientific software</p>
        <h2>Tools shaped by<br /><span>real analytical work.</span></h2>
      </div>
      <p>
        Purpose-built environments for traceable analysis, meaningful controls, and
        publication-ready scientific output.
      </p>
    </div>
    <div class="shell software-list">
      {
        products.map((product, index) => (
          <a
            class:list={['software-entry', `accent-${product.accent}`]}
            href={`/software/${product.slug}`}
            data-reveal
          >
            <span class="software-number">0{index + 1}</span>
            <div class="software-title">
              <small>{product.category}</small>
              <h3>{product.name}</h3>
            </div>
            <p>{product.summary}</p>
            <div class="software-status">
              <span>{product.status}</span>
              <b>↗</b>
            </div>
            <div class={`software-signal signal-${product.visual}`} aria-hidden="true">
              <>
                <i />
                <i />
                <i />
                <i />
              </>
            </div>
          </a>
        ))
      }
    </div>
    <div class="shell section-end" data-reveal>
      <a class="text-link" href="/software">View the software catalogue <span>↗</span></a>
    </div>
  </section>

  <section class="approach-section section-space">
    <div class="shell capability-heading" data-reveal>
      <p class="micro-label">04 / Integrated practice</p>
      <h2>Depth where it matters.<br /><span>Clarity everywhere.</span></h2>
    </div>
    <div class="shell capability-grid">
      {
        capabilities.map(([title, description], index) => (
          <article data-reveal>
            <span>{String(index + 1).padStart(2, '0')}</span>
            <h3>{title}</h3>
            <p>{description}</p>
          </article>
        ))
      }
    </div>
  </section>

  <section class="mission-section">
    <div class="shell mission-layout">
      <div class="mission-note" data-reveal>
        <span>Independent platform</span>
        <span>Nepal</span>
      </div>
      <div class="mission-copy" data-reveal>
        <p class="micro-label">BN Material</p>
        <h2>
          Scientific ambition,<br />
          <span>with evidence in command.</span>
        </h2>
        <p>
          Founded by {site.founder}, BN Material is a broad materials-engineering ecosystem:
          rigorous about scientific claims, explicit about product status, and designed to make
          complex work easier to understand.
        </p>
        <div class="mission-links">
          <a class="button button-light" href="/about"><span>About BN Material</span><b>↗</b></a>
          <a class="button button-dark" href="/contact"><span>Start a conversation</span><b>→</b></a
          >
        </div>
      </div>
    </div>
  </section>
</Base>
