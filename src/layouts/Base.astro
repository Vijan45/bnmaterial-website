---
import '../styles/global.css';
import '../styles/redesign.css';
import { site, topics, products } from '../config/site';

interface Props {
  title: string;
  description: string;
}

const { title, description } = Astro.props;
const canonical = new URL(Astro.url.pathname, site.url);
const pageTitle = title === site.name ? site.name : `${title} | ${site.name}`;
const path = Astro.url.pathname;
const isActive = (href: string) => (href === '/' ? path === '/' : path.startsWith(href));
const navTopics = topics.slice(0, 8);
const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'Organization',
    name: site.name,
    url: site.url,
    founder: { '@type': 'Person', name: site.founder },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    name: site.name,
    url: site.url,
    description: site.supportingLine,
  },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#050412" />
    <meta name="color-scheme" content="dark light" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={`${site.url}/og.png`} />
    <meta
      property="og:image:alt"
      content="BN Material — Materials engineered for what comes next."
    />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={`${site.url}/og.png`} />
    <link rel="icon" href="/favicon.svg" />
    <link rel="manifest" href="/site.webmanifest" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500&family=Manrope:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />
    <script is:inline>
      document.documentElement.classList.add('js');
    </script>
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </head>
  <body>
    <a class="skip-link" href="#main">Skip to content</a>
    <div class="scroll-progress" aria-hidden="true"></div>
    <div class="site-aurora" aria-hidden="true"></div>
    <header class="site-header">
      <div class="utility-bar">
        <div class="shell utility-inner">
          <span>Materials science · computation · scientific software</span>
          <span>Independent research platform · Nepal</span>
        </div>
      </div>
      <nav class="shell main-nav" aria-label="Primary navigation">
        <a class="brand" href="/" aria-label="BN Material home">
          <span class="brand-mark" aria-hidden="true">
            <i class="mark-b"></i>
            <i class="mark-n"></i>
            <i class="mark-fault"></i>
          </span>
          <span class="brand-name"
            ><strong><b>BN</b> Material</strong><small>Materials · models · meaning</small></span
          >
        </a>
        <button class="menu-toggle" type="button" aria-expanded="false" aria-controls="nav-panel">
          <span></span><span></span><span></span><b>Menu</b>
        </button>
        <div class="nav-panel" id="nav-panel">
          <a class:list={['nav-item', { active: isActive('/') }]} href="/">Home</a>
          <details class="nav-dropdown">
            <summary class:list={['nav-item', { active: isActive('/topics') }]}
              >Topics <span>+</span></summary
            >
            <div class="mega-menu">
              <div class="mega-intro">
                <p class="micro-label">Materials topics</p>
                <h2>One field.<br />Many connected scales.</h2>
                <p>Explore materials from electronic structure to manufacturing and deployment.</p>
                <a href="/topics">View all 12 topics <span>↗</span></a>
              </div>
              <div class="mega-grid">
                {
                  navTopics.map((topic, index) => (
                    <a href={`/topics/${topic.slug}`}>
                      <span>{String(index + 1).padStart(2, '0')}</span>
                      <strong>{topic.shortTitle}</strong>
                      <small>{topic.methods.slice(0, 2).join(' · ')}</small>
                    </a>
                  ))
                }
                <a class="mega-all" href="/topics">
                  <span>12</span><strong>All topics</strong><small
                    >Complete materials landscape</small
                  >
                </a>
              </div>
            </div>
          </details>
          <a class:list={['nav-item', { active: isActive('/research') }]} href="/research"
            >Research</a
          >
          <details class="nav-dropdown nav-dropdown-software">
            <summary class:list={['nav-item', { active: isActive('/software') }]}
              >Software <span>+</span></summary
            >
            <div class="software-menu">
              {
                products.map((product) => (
                  <a href={`/software/${product.slug}`}>
                    <small>{product.status}</small>
                    <strong>{product.name}</strong>
                    <span>{product.category} ↗</span>
                  </a>
                ))
              }
              <a class="software-menu-all" href="/software">Open catalogue →</a>
            </div>
          </details>
          <a class:list={['nav-item', { active: isActive('/publications') }]} href="/publications"
            >Publications</a
          >
          <a class:list={['nav-item', { active: isActive('/resources') }]} href="/resources"
            >Resources</a
          >
          <a class:list={['nav-item', { active: isActive('/about') }]} href="/about">About</a>
          <a class="nav-contact" href="/contact"><span>Contact</span><b>↗</b></a>
        </div>
      </nav>
    </header>

    <main id="main"><slot /></main>

    <footer class="site-footer">
      <div class="shell footer-primary">
        <div class="footer-brand">
          <a class="brand footer-wordmark" href="/" aria-label="BN Material home">
            <span class="brand-mark" aria-hidden="true">
              <i class="mark-b"></i>
              <i class="mark-n"></i>
              <i class="mark-fault"></i>
            </span>
            <span class="brand-name"
              ><strong><b>BN</b> Material</strong><small>Materials · models · meaning</small></span
            >
          </a>
          <p>
            A broad materials-engineering platform connecting scientific research, computation,
            characterization, data systems, and purpose-built software.
          </p>
          <a href="/contact">Start a scientific conversation <span>↗</span></a>
        </div>
        <div class="footer-links">
          <div>
            <small>Explore</small>
            <a href="/topics">Materials domains</a>
            <a href="/research">Research framework</a>
            <a href="/software">Scientific software</a>
            <a href="/publications">Publications</a>
          </div>
          <div>
            <small>Knowledge</small>
            <a href="/resources">Resources</a>
            <a href="/benchmarks">Benchmarks</a>
            <a href="/academy">Academy</a>
            <a href="/consulting">Consulting</a>
          </div>
          <div>
            <small>Organization</small>
            <a href="/about">About BN Material</a>
            <a href="/contact">Contact</a>
            <a href={site.sisterSite} target="_blank" rel="noopener noreferrer">bhijan.com.np ↗</a>
            <a href="/privacy-policy">Privacy policy</a>
          </div>
        </div>
      </div>
      <div class="shell footer-bottom">
        <span>© {new Date().getFullYear()} BN Material</span>
        <span>Materials engineering across scales</span>
        <span>Independent platform · Nepal</span>
      </div>
    </footer>

    <script is:inline>
      const menuButton = document.querySelector('.menu-toggle');
      const navPanel = document.querySelector('#nav-panel');
      const closeNavigation = () => {
        menuButton?.setAttribute('aria-expanded', 'false');
        navPanel?.classList.remove('open');
        document.body.classList.remove('nav-open');
        document
          .querySelectorAll('.nav-dropdown[open]')
          .forEach((item) => item.removeAttribute('open'));
      };

      menuButton?.addEventListener('click', () => {
        const open = menuButton.getAttribute('aria-expanded') !== 'true';
        menuButton.setAttribute('aria-expanded', String(open));
        navPanel?.classList.toggle('open', open);
        document.body.classList.toggle('nav-open', open);
      });

      document.addEventListener('keydown', (event) => {
        if (event.key === 'Escape') closeNavigation();
      });

      navPanel
        ?.querySelectorAll('a')
        .forEach((link) => link.addEventListener('click', closeNavigation));
      document.querySelectorAll('.nav-dropdown').forEach((dropdown) => {
        dropdown.addEventListener('toggle', () => {
          if (dropdown.open) {
            document.querySelectorAll('.nav-dropdown').forEach((other) => {
              if (other !== dropdown) other.removeAttribute('open');
            });
          }
        });
      });

      const revealItems = document.querySelectorAll('[data-reveal]');
      revealItems.forEach((item, index) => {
        item.style.setProperty('--reveal-order', String(index % 5));
      });
      if ('IntersectionObserver' in window) {
        const revealObserver = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add('is-visible');
                revealObserver.unobserve(entry.target);
              }
            });
          },
          { threshold: 0.12, rootMargin: '0px 0px -6% 0px' },
        );
        revealItems.forEach((item) => revealObserver.observe(item));
      } else {
        revealItems.forEach((item) => item.classList.add('is-visible'));
      }

      const header = document.querySelector('.site-header');
      const progress = document.querySelector('.scroll-progress');
      const updateHeader = () => {
        header?.classList.toggle('scrolled', window.scrollY > 20);
        const distance = document.documentElement.scrollHeight - innerHeight;
        const ratio = distance > 0 ? Math.min(1, Math.max(0, scrollY / distance)) : 0;
        progress?.style.setProperty('--scroll-progress', String(ratio));
      };
      updateHeader();
      window.addEventListener('scroll', updateHeader, { passive: true });

      if (matchMedia('(hover: hover) and (prefers-reduced-motion: no-preference)').matches) {
        const spectrum = document.querySelector('.hero-spectrum');
        spectrum?.addEventListener('pointermove', (event) => {
          const rect = spectrum.getBoundingClientRect();
          spectrum.style.setProperty('--pointer-x', `${event.clientX - rect.left}px`);
          spectrum.style.setProperty('--pointer-y', `${event.clientY - rect.top}px`);
          spectrum.style.setProperty(
            '--spectrum-tilt-x',
            `${((event.clientY - rect.top) / rect.height - 0.5) * -2.5}deg`,
          );
          spectrum.style.setProperty(
            '--spectrum-tilt-y',
            `${((event.clientX - rect.left) / rect.width - 0.5) * 3}deg`,
          );
        });
        spectrum?.addEventListener('pointerleave', () => {
          spectrum.style.setProperty('--spectrum-tilt-x', '0deg');
          spectrum.style.setProperty('--spectrum-tilt-y', '0deg');
        });

        document.querySelectorAll('[data-tilt]').forEach((card) => {
          card.addEventListener('pointermove', (event) => {
            const rect = card.getBoundingClientRect();
            card.style.setProperty(
              '--card-tilt-x',
              `${((event.clientY - rect.top) / rect.height - 0.5) * -2}deg`,
            );
            card.style.setProperty(
              '--card-tilt-y',
              `${((event.clientX - rect.left) / rect.width - 0.5) * 2.5}deg`,
            );
          });
          card.addEventListener('pointerleave', () => {
            card.style.setProperty('--card-tilt-x', '0deg');
            card.style.setProperty('--card-tilt-y', '0deg');
          });
        });
      }

      const motionQuery = matchMedia('(prefers-reduced-motion: reduce)');
      const canvasRecords = [];
      const clamp = (value, min, max) => Math.min(max, Math.max(min, value));

      const setupCanvas = (canvas, draw) => {
        const record = { canvas, draw, visible: true, width: 0, height: 0 };
        const resize = () => {
          const rect = canvas.getBoundingClientRect();
          const dpr = Math.min(devicePixelRatio || 1, 1.5);
          const width = Math.max(1, Math.round(rect.width * dpr));
          const height = Math.max(1, Math.round(rect.height * dpr));
          if (canvas.width !== width || canvas.height !== height) {
            canvas.width = width;
            canvas.height = height;
          }
          record.width = rect.width;
          record.height = rect.height;
          record.dpr = dpr;
          draw(record, 0);
        };
        record.resize = resize;
        canvasRecords.push(record);
        resize();
        new ResizeObserver(resize).observe(canvas);
        if ('IntersectionObserver' in window) {
          new IntersectionObserver(
            ([entry]) => {
              record.visible = entry.isIntersecting;
            },
            { rootMargin: '120px' },
          ).observe(canvas);
        }
        return record;
      };

      const fieldCanvas = document.querySelector('[data-field-canvas]');
      if (fieldCanvas) {
        const nodes = Array.from({ length: innerWidth < 700 ? 24 : 38 }, (_, index) => ({
          x: ((index * 47) % 101) / 100,
          y: ((index * 71 + 13) % 97) / 100,
          r: 0.8 + ((index * 11) % 17) / 10,
          phase: index * 0.73,
          speed: 0.45 + (index % 5) * 0.08,
        }));

        setupCanvas(fieldCanvas, (record, time) => {
          const { canvas, width, height, dpr } = record;
          const context = canvas.getContext('2d');
          if (!context || !width || !height) return;
          context.setTransform(dpr, 0, 0, dpr, 0, 0);
          context.clearRect(0, 0, width, height);
          const tick = motionQuery.matches ? 0 : time * 0.00016;
          const points = nodes.map((node, index) => ({
            x:
              width *
              clamp(
                node.x + Math.sin(tick * node.speed + node.phase) * (0.012 + (index % 3) * 0.004),
                0.035,
                0.965,
              ),
            y:
              height *
              clamp(node.y + Math.cos(tick * node.speed * 0.9 + node.phase) * 0.018, 0.035, 0.965),
            r: node.r,
            phase: node.phase,
          }));

          for (let a = 0; a < points.length; a += 1) {
            for (let b = a + 1; b < points.length; b += 1) {
              const dx = points[a].x - points[b].x;
              const dy = points[a].y - points[b].y;
              const distance = Math.hypot(dx, dy);
              const limit = Math.min(width, height) * 0.19;
              if (distance < limit) {
                context.beginPath();
                context.moveTo(points[a].x, points[a].y);
                context.lineTo(points[b].x, points[b].y);
                context.strokeStyle = `rgba(122, 210, 255, ${0.12 * (1 - distance / limit)})`;
                context.lineWidth = 0.7;
                context.stroke();
              }
            }
          }

          points.forEach((point, index) => {
            const pulse = 0.7 + Math.sin(tick * 3 + point.phase) * 0.25;
            const gradient = context.createRadialGradient(
              point.x,
              point.y,
              0,
              point.x,
              point.y,
              point.r * 5,
            );
            const warm = index % 11 === 0;
            gradient.addColorStop(
              0,
              warm ? 'rgba(255, 160, 225, .95)' : 'rgba(201, 255, 250, .95)',
            );
            gradient.addColorStop(
              0.22,
              warm ? 'rgba(239, 112, 202, .48)' : 'rgba(111, 230, 216, .52)',
            );
            gradient.addColorStop(1, 'rgba(111, 230, 216, 0)');
            context.beginPath();
            context.arc(point.x, point.y, point.r * 5 * pulse, 0, Math.PI * 2);
            context.fillStyle = gradient;
            context.fill();
          });
        });
      }

      document.querySelectorAll('[data-product-signal]').forEach((canvas) => {
        const kind = canvas.dataset.productSignal;
        setupCanvas(canvas, (record, time) => {
          const { canvas, width, height, dpr } = record;
          const context = canvas.getContext('2d');
          if (!context || !width || !height) return;
          context.setTransform(dpr, 0, 0, dpr, 0, 0);
          context.clearRect(0, 0, width, height);
          const accent = getComputedStyle(canvas.closest('.software-entry'))
            .getPropertyValue('--accent')
            .trim();
          const tick = motionQuery.matches ? 0 : time * 0.001;

          context.strokeStyle = 'rgba(190, 199, 235, .08)';
          context.lineWidth = 1;
          for (let x = 0; x <= width; x += width / 8) {
            context.beginPath();
            context.moveTo(x, 0);
            context.lineTo(x, height);
            context.stroke();
          }
          for (let y = 0; y <= height; y += height / 4) {
            context.beginPath();
            context.moveTo(0, y);
            context.lineTo(width, y);
            context.stroke();
          }

          if (kind === 'micrograph') {
            for (let index = 0; index < 44; index += 1) {
              const x = ((index * 83) % 101) * (width / 100);
              const y = ((index * 47 + 11) % 97) * (height / 100);
              const radius = 3 + ((index * 7) % 12);
              context.beginPath();
              context.arc(x, y, radius, 0, Math.PI * 2);
              context.fillStyle = `rgba(165, 176, 195, ${0.07 + (index % 4) * 0.025})`;
              context.fill();
              if (index % 9 === 0) {
                const scan = 0.55 + Math.sin(tick * 1.4 + index) * 0.22;
                context.strokeStyle = accent;
                context.globalAlpha = scan;
                context.strokeRect(x - radius - 3, y - radius - 3, radius * 2 + 6, radius * 2 + 6);
                context.globalAlpha = 1;
              }
            }
          } else {
            const peaks =
              kind === 'thermal'
                ? [
                    [0.26, 0.14, 0.55],
                    [0.48, 0.09, 0.86],
                    [0.71, 0.17, 0.64],
                  ]
                : [
                    [0.17, 0.038, 0.48],
                    [0.34, 0.025, 0.9],
                    [0.56, 0.045, 0.66],
                    [0.8, 0.03, 0.82],
                  ];
            context.beginPath();
            for (let x = 0; x <= width; x += 2) {
              const progress = x / width;
              let signal = kind === 'thermal' ? 0.07 + progress * 0.18 : 0.03;
              peaks.forEach(([center, spread, heightValue]) => {
                signal += heightValue * Math.exp(-Math.pow((progress - center) / spread, 2));
              });
              const y = height - 10 - signal * (height - 22);
              if (x === 0) context.moveTo(x, y);
              else context.lineTo(x, y);
            }
            context.strokeStyle = accent;
            context.lineWidth = 1.8;
            context.shadowColor = accent;
            context.shadowBlur = 9;
            context.stroke();
            context.shadowBlur = 0;
          }

          const scanX = ((tick * 32) % (width + 50)) - 25;
          const scanGradient = context.createLinearGradient(scanX - 18, 0, scanX + 18, 0);
          scanGradient.addColorStop(0, 'rgba(255,255,255,0)');
          scanGradient.addColorStop(0.5, 'rgba(255,255,255,.16)');
          scanGradient.addColorStop(1, 'rgba(255,255,255,0)');
          context.fillStyle = scanGradient;
          context.fillRect(scanX - 18, 0, 36, height);
        });
      });

      let animationFrame;
      let lastCanvasFrame = 0;
      const renderCanvases = (time) => {
        if (time - lastCanvasFrame >= 32) {
          canvasRecords.forEach((record) => {
            if (record.visible) record.draw(record, time);
          });
          lastCanvasFrame = time;
        }
        if (!motionQuery.matches && !document.hidden) {
          animationFrame = requestAnimationFrame(renderCanvases);
        }
      };
      const restartCanvases = () => {
        cancelAnimationFrame(animationFrame);
        lastCanvasFrame = 0;
        canvasRecords.forEach((record) => record.draw(record, 0));
        if (!motionQuery.matches && !document.hidden) {
          animationFrame = requestAnimationFrame(renderCanvases);
        }
      };
      motionQuery.addEventListener?.('change', restartCanvases);
      document.addEventListener('visibilitychange', restartCanvases);
      restartCanvases();
    </script>
  </body>
</html>
