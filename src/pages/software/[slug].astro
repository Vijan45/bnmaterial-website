---
import Base from '../../layouts/Base.astro';
import { products, site } from '../../config/site';

export function getStaticPaths() {
  return products.map((product, index) => ({
    params: { slug: product.slug },
    props: { product, index },
  }));
}

const { product, index } = Astro.props;
const ld = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: product.name,
  applicationCategory: 'ScienceApplication',
  description: product.summary,
  author: { '@type': 'Person', name: site.founder },
};
---

<Base title={product.name} description={product.summary}>
  <script type="application/ld+json" set:html={JSON.stringify(ld)} />
  <section class:list={['product-page-hero', `accent-${product.accent}`]}>
    <div class="shell product-page-hero-inner">
      <div class="product-page-hero-copy" data-reveal>
        <p class="eyebrow">BN software / 0{index + 1} / {product.category}</p>
        <h1>{product.name}</h1>
        <p>{product.summary}</p>
        <div class="hero-actions">
          <a class="button button-primary" href="/contact"><span>Discuss access</span><b>↗</b></a>
          <a class="button button-outline" href="#capabilities"><span>Capabilities</span><b>↓</b></a
          >
        </div>
      </div>
      <aside class="product-page-hero-aside" data-reveal>
        <span>Development status</span>
        <strong>{product.status}</strong>
        <p>
          Availability, platform support, versioning, and licensing are published only when
          confirmed.
        </p>
      </aside>
    </div>
  </section>

  <section class="product-workspace-section">
    <div class="shell">
      <div class="workspace-frame" data-reveal>
        <div class="workspace-toolbar">
          <small>BN MATERIAL / INTERFACE CONCEPT</small><strong>{product.name}</strong><small
            >Scientific workspace</small
          >
        </div>
        <aside class="workspace-sidebar">
          <b>BN</b>
          {
            ['Import', 'Analyze', 'Annotate', 'Compare', 'Export'].map((item, i) => (
              <span class:list={[{ active: i === 1 }]}>
                <i>0{i + 1}</i>
                {item}
              </span>
            ))
          }
        </aside>
        <div class="workspace-main">
          <div class="workspace-main-header">
            <span>Primary analysis view</span><b>{product.category}</b>
          </div>
          <div class:list={['workspace-plot', product.visual]} aria-hidden="true">
            {
              product.visual === 'micrograph' &&
                Array.from({ length: 20 }).map((_, i) => <i style={`--i:${i}`} />)
            }
          </div>
        </div>
        <aside class="workspace-inspector">
          <span>Analysis parameters</span>
          <label>Signal profile<i style="--value:78%"></i></label>
          <label>Threshold<i style="--value:46%"></i></label>
          <label>Resolution<i style="--value:67%"></i></label>
          <p>
            Conceptual interface visualization. It is not experimental data and does not establish
            implemented capability.
          </p>
        </aside>
      </div>
    </div>
  </section>

  <section class="page-section light" id="capabilities">
    <div class="shell capability-list-layout">
      <aside class="capability-list-intro" data-reveal>
        <p class="micro-label">Scientific workflow</p>
        <h2>Capability with visible boundaries.</h2>
        <p>
          Implemented positioning, roadmap items, access status, and scientific controls are
          separated so users can distinguish present functionality from future development.
        </p>
        <a class="text-link" href="/contact">Contact BN Material <span>↗</span></a>
      </aside>
      <div class="capability-list-content">
        <div data-reveal>
          <span>01 / Current capability</span>
          <h3>Core analysis environment</h3>
          <ul>{product.features.map((feature) => <li>{feature}</li>)}</ul>
        </div>
        <div data-reveal>
          <span>02 / Development roadmap</span>
          <h3>Planned extensions</h3>
          <ul>{product.planned.map((feature) => <li>{feature}</li>)}</ul>
        </div>
        <div data-reveal>
          <span>03 / Release discipline</span>
          <h3>Access, validation, and licensing</h3>
          <p>
            Public downloads are not presented until the executable, platform support,
            documentation, version, validation status, and licensing terms are ready for review.
          </p>
        </div>
      </div>
    </div>
  </section>
</Base>
