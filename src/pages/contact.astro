---
import Base from '../layouts/Base.astro';
import { site } from '../config/site';
---

<Base
  title="Contact"
  description="Contact BN Material about software access, research collaboration, consulting, training, support, or general inquiries."
  ><section class="page-hero container">
    <p class="eyebrow">Contact</p><h1>Start a focused scientific conversation.</h1><p class="lead">
      The secure server endpoint is not yet configured and the public mailbox has not been
      independently confirmed. The interface below prepares an inquiry, then uses your email client.
    </p>
  </section><section>
    <div class="container grid">
      <form class="card" id="contact-form">
        <label for="name">Name</label><input
          id="name"
          name="name"
          required
          autocomplete="name"
        /><label for="email">Email</label><input
          id="email"
          name="email"
          type="email"
          required
          autocomplete="email"
        /><label for="category">Inquiry category</label><select id="category" name="category"
          ><option>Software access</option><option>Research collaboration</option><option
            >Consulting</option
          ><option>Training and academy</option><option>Technical support</option><option
            >General inquiry</option
          ></select
        ><label for="message">Message</label><textarea id="message" name="message" required
        ></textarea><div hidden>
          <label for="website">Leave blank</label><input
            id="website"
            name="website"
            tabindex="-1"
            autocomplete="off"
          />
        </div><p class="muted">
          By continuing, you choose to share these details by email for the purpose of receiving a
          response.
        </p><button class="button" type="submit">Prepare email</button><p
          id="form-status"
          role="status"
        >
        </p>
      </form><aside class="card">
        <h2>Email fallback</h2><p>
          Once the Zoho mailbox or alias is confirmed, inquiries can be sent to <strong
            >{site.contactEmail}</strong
          >.
        </p><p class="muted">
          No password, SMTP credential, or visitor submission is stored by this website.
        </p>
      </aside>
    </div>
  </section><script define:vars={{ email: site.contactEmail }}>
    document.querySelector('#contact-form')?.addEventListener('submit', (e) => {
      e.preventDefault();
      const f = new FormData(e.currentTarget);
      if (f.get('website')) return;
      const subject = encodeURIComponent(`BN Material — ${f.get('category')}`);
      const body = encodeURIComponent(
        `Name: ${f.get('name')}\nEmail: ${f.get('email')}\n\n${f.get('message')}`,
      );
      document.querySelector('#form-status').textContent =
        'Opening your email application. Please verify the recipient before sending.';
      location.href = `mailto:${email}?subject=${subject}&body=${body}`;
    });
  </script></Base
>
