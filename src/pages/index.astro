---
import Base from '../layouts/Base.astro';
import { engineeringScales, products, site, topics } from '../config/site';

const featuredTopics = topics.slice(0, 8);
const capabilities = [
  ['Experiment', 'Synthesis, processing, characterization, and mechanism-aware validation.'],
  [
    'Computation',
    'Electronic structure, molecular dynamics, simulation, and model-based interpretation.',
  ],
  [
    'Data systems',
    'Reproducible analysis, materials informatics, automation, and scientific visualization.',
  ],
  [
    'Translation',
    'From physical understanding to devices, software, manufacturing, and deployment.',
  ],
];
---

<Base
  title="BN Material"
  description="A broad materials-engineering platform spanning crystal engineering, molecular dynamics, semiconductors, solar cells, biomaterials, ceramics, polymers, nanomaterials, metallurgy, catalysis, characterization, and processing."
>
  <section class="hero">
    <canvas id="grain-field" aria-hidden="true"></canvas>
    <div class="hero-mesh" aria-hidden="true"></div>
    <div class="shell hero-layout">
      <div class="hero-copy" data-reveal>
        <div class="hero-kicker">
          <span class="live-mark"></span>
          <span>Materials engineering · research · scientific software</span>
        </div>
        <h1>
          Engineering matter<br />
          <span>across every scale.</span>
        </h1>
        <p class="hero-lead">
          BN Material connects atomic mechanisms, microstructure, processing, properties, and
          real-world performance across the full materials-science landscape.
        </p>
        <div class="hero-actions">
          <a class="button button-primary" href="/topics"
            ><span>Explore materials domains</span><b>↗</b></a
          >
          <a class="button button-outline" href="/research"
            ><span>Research framework</span><b>→</b></a
          >
        </div>
        <div class="hero-index" aria-label="Platform coverage">
          <div><strong>12</strong><span>Materials domains</span></div>
          <div><strong>06</strong><span>Engineering scales</span></div>
          <div><strong>03</strong><span>Scientific software systems</span></div>
        </div>
      </div>

      <div class="atlas-panel" data-reveal>
        <div class="atlas-head">
          <span>LIVE MATERIALS ATLAS</span>
          <b>Mechanisms / 01—06</b>
          <i></i>
        </div>
        <div class="phenomena-grid">
          <article class="phenomenon phenomenon-crystal">
            <div class="phenomenon-meta"><span>01</span><b>Self-healing crystal</b></div>
            <svg viewBox="0 0 240 142" aria-hidden="true">
              <g class="lattice-lines" stroke="currentColor" stroke-width="1">
                <path d="M20 24h200M20 58h200M20 92h200M20 126h200"></path>
                <path d="M36 8v126M76 8v126M116 8v126M156 8v126M196 8v126"></path>
              </g>
              <path
                class="crack"
                d="M119 10 103 37l20 18-19 24 17 18-12 36"
                fill="none"
                stroke-width="3"></path>
              <path
                class="healing-front"
                d="M119 10 103 37l20 18-19 24 17 18-12 36"
                fill="none"
                stroke-width="5"></path>
              <g class="lattice-nodes">
                {
                  Array.from({ length: 30 }).map((_, i) => (
                    <circle cx={36 + (i % 5) * 40} cy={24 + Math.floor(i / 5) * 17} r="2.5" />
                  ))
                }
              </g>
            </svg>
            <small>Crack closure · defect mobility</small>
          </article>

          <article class="phenomenon phenomenon-md">
            <div class="phenomenon-meta"><span>02</span><b>Molecular dynamics</b></div>
            <svg viewBox="0 0 240 142" aria-hidden="true">
              <g class="trajectory" fill="none" stroke-width="1.2">
                <path d="M16 102C54 28 88 122 126 54s62 52 99-17"></path>
                <path d="M15 52c37 70 73-37 111 24s61-63 99 20"></path>
                <path d="M27 122c19-55 63-47 86-12s69 4 98-75"></path>
              </g>
              <g class="md-particles">
                {
                  Array.from({ length: 12 }).map((_, i) => (
                    <circle
                      style={`--i:${i}`}
                      cx={24 + (i % 6) * 37}
                      cy={30 + Math.floor(i / 6) * 67}
                      r={i % 3 === 0 ? 5 : 3.5}
                    />
                  ))
                }
              </g>
            </svg>
            <small>Trajectory · energy · transport</small>
          </article>

          <article class="phenomenon phenomenon-junction">
            <div class="phenomenon-meta"><span>03</span><b>Heterojunction</b></div>
            <svg viewBox="0 0 240 142" aria-hidden="true">
              <rect x="18" y="24" width="96" height="94" rx="3" class="layer-a"></rect>
              <rect x="126" y="24" width="96" height="94" rx="3" class="layer-b"></rect>
              <path d="M26 84h73l18-24 16 18h81" class="band band-c"></path>
              <path d="M26 104h78l13-18 16 12h81" class="band band-v"></path>
              <g class="carriers">
                <circle cx="45" cy="75" r="4"></circle><circle cx="78" cy="75" r="4"
                ></circle><circle cx="159" cy="91" r="4"></circle><circle cx="194" cy="91" r="4"
                ></circle>
              </g>
              <path d="M104 18v106" class="interface-line"></path>
            </svg>
            <small>Band alignment · carrier transfer</small>
          </article>

          <article class="phenomenon phenomenon-solar">
            <div class="phenomenon-meta"><span>04</span><b>Solar conversion</b></div>
            <svg viewBox="0 0 240 142" aria-hidden="true">
              <g class="photons">
                <path d="M28 14l24 31"></path><path d="M71 11l19 35"></path><path d="M117 13l13 32"
                ></path><path d="M162 12l7 35"></path>
              </g>
              <path d="M18 52h204v18H18z" class="solar-layer top"></path>
              <path d="M18 72h204v28H18z" class="solar-layer middle"></path>
              <path d="M18 102h204v18H18z" class="solar-layer bottom"></path>
              <path d="M37 86c27-20 53 20 80 0s54 20 85 0" class="charge-wave"></path>
              <g class="solar-carriers"
                ><circle cx="42" cy="85" r="3"></circle><circle cx="102" cy="85" r="3"
                ></circle><circle cx="164" cy="85" r="3"></circle></g
              >
            </svg>
            <small>Photon capture · charge extraction</small>
          </article>

          <article class="phenomenon phenomenon-polymer">
            <div class="phenomenon-meta"><span>05</span><b>Polymer mechanics</b></div>
            <svg viewBox="0 0 240 142" aria-hidden="true">
              <path
                class="polymer-chain"
                d="M15 80c18-43 34 38 52-5s34 38 52-5 34 38 52-5 34 38 54-8"
                fill="none"
                stroke-width="3"></path>
              <g class="polymer-beads">
                <circle cx="15" cy="80" r="5"></circle><circle cx="41" cy="59" r="5"
                ></circle><circle cx="67" cy="75" r="5"></circle><circle cx="93" cy="54" r="5"
                ></circle><circle cx="119" cy="70" r="5"></circle><circle cx="145" cy="49" r="5"
                ></circle><circle cx="171" cy="65" r="5"></circle><circle cx="199" cy="48" r="5"
                ></circle><circle cx="225" cy="57" r="5"></circle>
              </g>
              <path d="M23 117h194" class="strain-axis"></path><path d="m23 117 10-6v12Z"
              ></path><path d="m217 117-10-6v12Z"></path>
            </svg>
            <small>Chain dynamics · viscoelasticity</small>
          </article>

          <article class="phenomenon phenomenon-grain">
            <div class="phenomenon-meta"><span>06</span><b>Microstructure</b></div>
            <svg viewBox="0 0 240 142" aria-hidden="true">
              <g class="grain-map" fill="none" stroke-width="1.4">
                <path d="M4 12 49 3l24 27-10 40-41 10L2 55Z"></path><path
                  d="m49 3 48 8 16 35-26 32-24-8 10-40Z"></path><path
                  d="m97 11 50-6 17 30-15 40-36-29Z"></path><path
                  d="m147 5 43 11 20 35-31 28-30-4 15-40Z"></path><path d="m190 16 48-4v55l-28-16Z"
                ></path><path d="m2 55 20 25 2 55H2Z"></path><path
                  d="m22 80 41-10 28 33-17 35-50-3Z"></path><path
                  d="m63 70 24 8 26-32 36 29-8 43-50-15Z"></path><path
                  d="m149 75 30 4 31-28 28 16v71h-49l-48-20Z"></path>
              </g>
              <circle class="grain-nucleus" cx="118" cy="82" r="5"></circle>
              <circle class="grain-growth" cx="118" cy="82" r="5" fill="none"></circle>
            </svg>
            <small>Grain evolution · phase topology</small>
          </article>
        </div>
        <div class="atlas-footer">
          <span>Scientifically grounded conceptual animations</span><b>Reduced-motion compatible</b>
        </div>
      </div>
    </div>
    <div class="shell hero-ticker" aria-label="Materials engineering domains">
      <span>Crystal engineering</span><i></i><span>Molecular dynamics</span><i></i><span
        >Anticancer materials</span
      ><i></i><span>Solar cells</span><i></i><span>Heterojunctions</span><i></i><span>Ceramics</span
      ><i></i><span>Polymers</span>
    </div>
  </section>

  <section class="domains-section section-space">
    <div class="shell section-heading" data-reveal>
      <div>
        <p class="micro-label">01 / Complete materials landscape</p>
        <h2>
          Broader than a single technique.<br /><span>Structured around engineering questions.</span
          >
        </h2>
      </div>
      <p>
        The platform is organized around mechanisms and material classes—not decorative
        categories—so experimental, computational, biological, electronic, and manufacturing
        perspectives remain connected.
      </p>
    </div>
    <div class="shell domain-grid">
      {
        featuredTopics.map((topic, index) => (
          <a
            class:list={['domain-card', `accent-${topic.accent}`]}
            href={`/topics/${topic.slug}`}
            data-reveal
            data-tilt
          >
            <div class="domain-card-top">
              <>
                <span>{String(index + 1).padStart(2, '0')}</span>
                <b>{topic.methods[0]}</b>
              </>
            </div>
            <div class:list={['domain-symbol', `symbol-${topic.visual}`]} aria-hidden="true">
              <>
                <i />
                <i />
                <i />
                <i />
              </>
            </div>
            <h3>{topic.title}</h3>
            <p>{topic.summary}</p>
            <div class="domain-tags">
              {topic.methods.slice(0, 3).map((method) => (
                <span>{method}</span>
              ))}
            </div>
            <strong class="card-link">
              Explore domain <span>↗</span>
            </strong>
          </a>
        ))
      }
    </div>
    <div class="shell domains-more" data-reveal>
      <a href="/topics">
        <span>Explore the complete atlas</span>
        <strong>12 connected materials-engineering domains</strong>
        <b>↗</b>
      </a>
    </div>
  </section>

  <section class="scale-section section-space">
    <div class="shell scale-layout">
      <div class="scale-intro" data-reveal>
        <p class="micro-label">02 / Multiscale engineering</p>
        <h2>From electrons<br />to industrial systems.</h2>
        <p>
          Materials performance emerges through connected scales. BN Material keeps those links
          visible—from bonding and defect physics to processing windows, device behavior,
          reliability, and sustainable deployment.
        </p>
        <a class="text-link" href="/research">See the research logic <span>↗</span></a>
      </div>
      <div class="scale-stack" data-reveal>
        {
          engineeringScales.map(([scale, description], index) => (
            <article style={`--scale-index:${index}`}>
              <span>{String(index + 1).padStart(2, '0')}</span>
              <div>
                <>
                  <h3>{scale}</h3>
                  <p>{description}</p>
                </>
              </div>
              <i />
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="capability-section section-space">
    <div class="shell capability-heading" data-reveal>
      <p class="micro-label">03 / Integrated practice</p>
      <h2>Research depth, computational rigor,<br />and software discipline.</h2>
    </div>
    <div class="shell capability-grid">
      {
        capabilities.map(([title, description], index) => (
          <article data-reveal>
            <span>{String(index + 1).padStart(2, '0')}</span>
            <h3>{title}</h3>
            <p>{description}</p>
            <div class={`capability-graphic capability-graphic-${index + 1}`} aria-hidden="true">
              <>
                <i />
                <i />
                <i />
              </>
            </div>
          </article>
        ))
      }
    </div>
  </section>

  <section class="software-section section-space">
    <div class="shell software-heading" data-reveal>
      <div>
        <p class="micro-label">04 / Scientific software</p>
        <h2>Analysis environments built<br />around real laboratory workflows.</h2>
      </div>
      <a class="text-link" href="/software">View software catalogue <span>↗</span></a>
    </div>
    <div class="shell product-grid">
      {
        products.map((product, index) => (
          <a
            class:list={['product-card', `product-${product.accent}`]}
            href={`/software/${product.slug}`}
            data-reveal
            data-tilt
          >
            <div class="product-meta">
              <>
                <span>0{index + 1}</span>
                <b>{product.status}</b>
              </>
            </div>
            <div
              class:list={['product-visual', `product-visual-${product.visual}`]}
              aria-hidden="true"
            >
              <div class="visual-toolbar">
                <>
                  <i />
                  <i />
                  <i />
                </>
              </div>
              <div class="visual-canvas">
                {Array.from({ length: 12 }).map((_, i) => (
                  <i style={`--i:${i}`} />
                ))}
              </div>
            </div>
            <small>{product.category}</small>
            <h3>{product.name}</h3>
            <p>{product.summary}</p>
            <strong>
              Explore system <span>↗</span>
            </strong>
          </a>
        ))
      }
    </div>
  </section>

  <section class="mission-section">
    <div class="shell mission-layout">
      <div class="mission-mark" data-reveal aria-hidden="true">
        <img src="/brand/bn-monogram-mono.svg" alt="" />
        <i></i><i></i><i></i>
      </div>
      <div class="mission-copy" data-reveal>
        <p class="micro-label">05 / Independent scientific platform</p>
        <h2>Built for evidence,<br /><span>not visual noise.</span></h2>
        <p>
          Founded by {site.founder}, BN Material is designed as a serious materials-engineering
          ecosystem: broad in scope, conservative in scientific claims, and precise about the
          boundary between measured evidence, computational interpretation, conceptual graphics, and
          software capability.
        </p>
        <div class="mission-links">
          <a class="button button-light" href="/about"><span>About BN Material</span><b>↗</b></a>
          <a class="button button-dark" href="/contact"><span>Contact</span><b>→</b></a>
        </div>
      </div>
    </div>
  </section>

  <script is:inline>
    const canvas = document.querySelector('#grain-field');
    const reducedMotion = matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (canvas && !reducedMotion) {
      const context = canvas.getContext('2d');
      const nodes = [];
      let width = 0;
      let height = 0;
      let animationFrame = 0;
      const pointer = { x: -1000, y: -1000 };

      const resize = () => {
        const ratio = Math.min(window.devicePixelRatio || 1, 1.6);
        width = canvas.clientWidth;
        height = canvas.clientHeight;
        canvas.width = Math.round(width * ratio);
        canvas.height = Math.round(height * ratio);
        context.setTransform(ratio, 0, 0, ratio, 0, 0);
        nodes.length = 0;
        const count = Math.max(24, Math.min(54, Math.round(width / 32)));
        for (let index = 0; index < count; index += 1) {
          nodes.push({
            x: Math.random() * width,
            y: Math.random() * height,
            vx: (Math.random() - 0.5) * 0.09,
            vy: (Math.random() - 0.5) * 0.09,
          });
        }
      };

      const draw = () => {
        context.clearRect(0, 0, width, height);
        nodes.forEach((node) => {
          node.x += node.vx;
          node.y += node.vy;
          if (node.x < -30 || node.x > width + 30) node.vx *= -1;
          if (node.y < -30 || node.y > height + 30) node.vy *= -1;
          const distance = Math.hypot(pointer.x - node.x, pointer.y - node.y);
          if (distance < 170 && distance > 0) {
            node.x -= ((pointer.x - node.x) / distance) * 0.18;
            node.y -= ((pointer.y - node.y) / distance) * 0.18;
          }
        });
        for (let a = 0; a < nodes.length; a += 1) {
          for (let b = a + 1; b < nodes.length; b += 1) {
            const distance = Math.hypot(nodes[a].x - nodes[b].x, nodes[a].y - nodes[b].y);
            if (distance < 165) {
              context.strokeStyle = `rgba(111, 213, 242, ${0.06 * (1 - distance / 165)})`;
              context.lineWidth = 1;
              context.beginPath();
              context.moveTo(nodes[a].x, nodes[a].y);
              context.lineTo(nodes[b].x, nodes[b].y);
              context.stroke();
            }
          }
          context.fillStyle = 'rgba(148, 231, 255, 0.16)';
          context.beginPath();
          context.arc(nodes[a].x, nodes[a].y, 1.2, 0, Math.PI * 2);
          context.fill();
        }
        animationFrame = requestAnimationFrame(draw);
      };

      canvas.addEventListener('pointermove', (event) => {
        const rect = canvas.getBoundingClientRect();
        pointer.x = event.clientX - rect.left;
        pointer.y = event.clientY - rect.top;
      });
      canvas.addEventListener('pointerleave', () => {
        pointer.x = -1000;
        pointer.y = -1000;
      });
      window.addEventListener('resize', resize, { passive: true });
      document.addEventListener('visibilitychange', () => {
        if (document.hidden) cancelAnimationFrame(animationFrame);
        else animationFrame = requestAnimationFrame(draw);
      });
      resize();
      animationFrame = requestAnimationFrame(draw);
    }
  </script>
</Base>
