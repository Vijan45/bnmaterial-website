---
import Base from '../../layouts/Base.astro';
import { products, site } from '../../config/site';
export function getStaticPaths() {
  return products.map((product) => ({ params: { slug: product.slug }, props: { product } }));
}
const { product } = Astro.props;
const index = products.findIndex((item) => item.slug === product.slug);
const ld = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: product.name,
  applicationCategory: 'ScienceApplication',
  operatingSystem: 'Not yet specified',
  description: product.summary,
  author: { '@type': 'Person', name: site.founder },
};
---

<Base title={product.name} description={product.summary}>
  <script type="application/ld+json" set:html={JSON.stringify(ld)} />
  <section class:list={['product-hero', `product-${product.accent}`]}>
    <div class="shell product-hero-grid">
      <div class="product-hero-copy">
        <div class="product-hero-meta">
          <span>BN / SOFTWARE — 0{index + 1}</span><span class="status"
            ><i></i>{product.status}</span
          >
        </div>
        <p class="eyebrow">{product.category}</p>
        <h1>{product.name}</h1>
        <p class="lead">{product.summary}</p>
        <div class="actions">
          <a class="button" href="/contact"><span>Request access</span><b>↗</b></a><a
            class="button ghost"
            href="#capabilities"><span>View capabilities</span><b>↓</b></a
          >
        </div>
      </div>
      <div class="product-hero-signal" aria-hidden="true">
        <span>0{index + 1}</span><div class:list={['signal-glyph', `glyph-${index + 1}`]}>
          {index === 1 && Array.from({ length: 16 }).map((_, i) => <i style={`--n:${i}`} />)}
        </div><small>Conceptual interface visual<br />Not experimental data</small>
      </div>
    </div>
  </section>
  <section class="product-interface-section">
    <div class="shell">
      <div class="interface-label">
        <span>Interface study / {product.category}</span><span
          >Concept model — not experimental data</span
        >
      </div>
      <div class="product-detail-interface" data-reveal>
        <div class="detail-toolbar">
          <span><i></i><i></i><i></i></span><strong>{product.name}</strong><small
            >Workspace / 01</small
          >
        </div>
        <div class="detail-sidebar">
          <b>BN</b>{
            ['Import', 'Analyze', 'Annotate', 'Compare', 'Export'].map((item, i) => (
              <span class:list={[{ active: i === 1 }]}>
                <i>0{i + 1}</i>
                {item}
              </span>
            ))
          }
        </div>
        <div class="detail-canvas">
          <div class="detail-title">
            <span>ANALYSIS VIEW</span><b>{product.category}</b><small>Conceptual dataset</small>
          </div>
          <div class:list={['detail-plot', `detail-plot-${index + 1}`]}>
            {index === 1 && Array.from({ length: 18 }).map((_, i) => <i style={`--n:${i}`} />)}
          </div>
          <div class="detail-footer">
            <span><b>STATUS</b>READY</span><span><b>MODE</b>RESEARCH</span><span
              ><b>VIEW</b>PRIMARY</span
            ><span><b>OUTPUT</b>FIGURE</span>
          </div>
        </div>
        <div class="detail-inspector">
          <span>PROPERTIES</span><label>Signal profile<i style="--v:78%"></i></label><label
            >Threshold<i style="--v:46%"></i></label
          ><label>Resolution<i style="--v:67%"></i></label><div>
            <small>ANNOTATION</small><p>
              Scientific controls remain visible and traceable throughout the workflow.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>
  <section class="capability-section" id="capabilities">
    <div class="shell capability-grid">
      <div class="capability-intro" data-reveal>
        <span class="section-index">Capabilities / evidence-based</span><h2>
          Designed around the <em>scientific workflow.</em>
        </h2><p>
          Implemented and planned capabilities are separated clearly. Access, licensing, platform
          support, and version remain configurable until a reviewed release is available.
        </p><a class="text-link" href="/contact">Contact the developer <span>↗</span></a>
      </div>
      <div class="capability-list">
        <div data-reveal>
          <span>01 / Current positioning</span>{
            product.features.length ? (
              <ul>
                {product.features.map((x) => (
                  <li>
                    <i />
                    {x}
                  </li>
                ))}
              </ul>
            ) : (
              <p>
                No executable or source evidence was supplied. The product is therefore described
                only as a developing environment.
              </p>
            )
          }
        </div>
        <div data-reveal>
          <span>02 / Development roadmap</span><ul>
            {
              product.planned.map((x) => (
                <li>
                  <i />
                  {x}
                </li>
              ))
            }
          </ul>
        </div>
        <div data-reveal>
          <span>03 / Access &amp; licensing</span><p>
            No public download is offered. Access method, platform, version, and licensing will be
            published only after review.
          </p>
        </div>
      </div>
    </div>
  </section>
  <section class="next-product">
    <div class="shell">
      <span>Continue exploring</span><a href="/software"
        >View the full software catalogue <b>↗</b></a
      >
    </div>
  </section>
</Base>

<style>
  .product-hero {
    min-height: calc(100svh - 7.25rem);
    position: relative;
    overflow: hidden;
    border-bottom: 1px solid var(--line);
  }
  .product-hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(var(--line) 1px, transparent 1px),
      linear-gradient(90deg, var(--line) 1px, transparent 1px);
    background-size: 7.14vw 7.14vw;
    mask-image: linear-gradient(90deg, transparent, #000);
    opacity: 0.24;
  }
  .product-hero-grid {
    min-height: inherit;
    display: grid;
    grid-template-columns: 1.15fr 0.85fr;
    gap: 6vw;
    align-items: center;
    position: relative;
  }
  .product-hero-copy {
    padding-block: 6rem;
  }
  .product-hero-meta {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: clamp(4rem, 9vh, 7rem);
    color: #566579;
    font:
      0.56rem IBM Plex Mono,
      monospace;
    letter-spacing: 0.1em;
  }
  .product-hero-copy h1 {
    max-width: 50rem;
    margin: 1.2rem 0 1.8rem;
    font:
      500 clamp(4rem, 7.8vw, 8rem)/0.86 Space Grotesk,
      sans-serif;
    letter-spacing: -0.075em;
  }
  .product-hero-copy .lead {
    max-width: 40rem;
    color: #93a1b0;
    font-size: 1.05rem;
  }
  .product-hero-copy .actions {
    margin-top: 3rem;
  }
  .product-hero-signal {
    position: relative;
    height: min(44rem, 70vh);
    border-left: 1px solid var(--line);
    display: grid;
    place-items: center;
  }
  .product-hero-signal > span {
    position: absolute;
    right: 0;
    top: 0;
    color: #263342;
    font:
      400 12rem/1 Space Grotesk,
      sans-serif;
    letter-spacing: -0.1em;
  }
  .product-hero-signal small {
    position: absolute;
    right: 0;
    bottom: 0;
    text-align: right;
    color: #536174;
    font:
      0.52rem/1.6 IBM Plex Mono,
      monospace;
    text-transform: uppercase;
  }
  .signal-glyph {
    position: relative;
    width: 80%;
    aspect-ratio: 1;
  }
  .signal-glyph::before,
  .signal-glyph::after {
    content: '';
    position: absolute;
    inset: 10%;
    border: 1px solid var(--line);
    border-radius: 50%;
  }
  .signal-glyph::after {
    inset: 27%;
  }
  .glyph-1 {
    background: linear-gradient(90deg, var(--blue), var(--violet));
    clip-path: polygon(
      0 58%,
      8% 56%,
      13% 30%,
      15% 57%,
      27% 54%,
      36% 47%,
      42% 55%,
      48% 4%,
      51% 56%,
      63% 51%,
      70% 26%,
      72% 54%,
      84% 49%,
      91% 12%,
      94% 53%,
      100% 47%,
      100% 60%,
      0 60%
    );
    opacity: 0.65;
  }
  .glyph-2 i {
    position: absolute;
    width: 2.5rem;
    height: 2.5rem;
    left: calc(5% + var(--n) * 5%);
    top: calc(8% + var(--n) * 3.4%);
    border: 1px solid var(--green);
    border-radius: 47% 53% 42% 58%;
    box-shadow: 0 0 24px rgba(92, 227, 184, 0.16);
  }
  .glyph-3 {
    border-left: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
    height: 60%;
    top: 18%;
  }
  .glyph-3::before {
    inset: 0;
    border: 0;
    border-radius: 0;
    background: var(--amber);
    clip-path: polygon(
      0 5%,
      12% 12%,
      20% 24%,
      29% 55%,
      41% 69%,
      52% 73%,
      66% 79%,
      78% 82%,
      90% 85%,
      100% 87%,
      100% 100%,
      0 100%
    );
    opacity: 0.5;
  }
  .product-interface-section {
    padding-block: 8rem;
    background: #080b11;
  }
  .interface-label {
    display: flex;
    justify-content: space-between;
    margin-bottom: 1rem;
    color: #59687a;
    font:
      0.52rem IBM Plex Mono,
      monospace;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }
  .product-detail-interface {
    height: 48rem;
    display: grid;
    grid-template-columns: 9rem minmax(0, 1fr) 17rem;
    grid-template-rows: 3.5rem 1fr;
    border: 1px solid var(--line);
    background: #06090e;
    box-shadow: 0 40px 100px rgba(0, 0, 0, 0.4);
  }
  .detail-toolbar {
    grid-column: 1/-1;
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    padding: 0 1rem;
    border-bottom: 1px solid var(--line);
    color: #5d6b7d;
    font:
      0.53rem IBM Plex Mono,
      monospace;
  }
  .detail-toolbar > span {
    display: flex;
    gap: 0.4rem;
  }
  .detail-toolbar i {
    width: 0.4rem;
    height: 0.4rem;
    border: 1px solid #526072;
    border-radius: 50%;
  }
  .detail-toolbar small {
    justify-self: end;
  }
  .detail-sidebar {
    display: flex;
    flex-direction: column;
    border-right: 1px solid var(--line);
  }
  .detail-sidebar > b {
    height: 5rem;
    display: grid;
    place-items: center;
    border-bottom: 1px solid var(--line);
    color: var(--blue);
    font: 500 1.3rem Space Grotesk;
  }
  .detail-sidebar > span {
    display: flex;
    align-items: center;
    gap: 0.7rem;
    padding: 1rem;
    color: #657486;
    font-size: 0.63rem;
    border-bottom: 1px solid var(--line);
  }
  .detail-sidebar > span.active {
    color: var(--white);
    background: rgba(120, 225, 255, 0.06);
  }
  .detail-sidebar > span i {
    color: #3e4b5c;
    font:
      0.48rem IBM Plex Mono,
      monospace;
  }
  .detail-canvas {
    position: relative;
    padding: 2rem 2.5rem;
  }
  .detail-title {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 0.25rem;
    color: #536174;
    font:
      0.48rem IBM Plex Mono,
      monospace;
  }
  .detail-title b {
    grid-row: 1/3;
    grid-column: 2;
    color: #8f9ca9;
    font-size: 0.6rem;
  }
  .detail-plot {
    position: absolute;
    left: 2.5rem;
    right: 2.5rem;
    top: 6rem;
    bottom: 6rem;
    border-left: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
    background-image:
      linear-gradient(var(--line) 1px, transparent 1px),
      linear-gradient(90deg, var(--line) 1px, transparent 1px);
    background-size: 12.5% 16.67%;
  }
  .detail-plot-1::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(90deg, var(--blue), var(--violet));
    clip-path: polygon(
      0 95%,
      11% 91%,
      17% 77%,
      20% 92%,
      31% 88%,
      39% 50%,
      42% 90%,
      52% 83%,
      58% 8%,
      61% 87%,
      72% 80%,
      80% 57%,
      83% 84%,
      92% 78%,
      97% 25%,
      100% 80%,
      100% 100%,
      0 100%
    );
    opacity: 0.6;
  }
  .detail-plot-2 i {
    position: absolute;
    width: 2rem;
    height: 2rem;
    left: calc(4% + var(--n) * 5%);
    top: calc(8% + var(--n) * 3.2%);
    border: 1px solid var(--green);
    border-radius: 45% 55% 38% 62%;
    box-shadow: 0 0 18px rgba(92, 227, 184, 0.12);
  }
  .detail-plot-3::before {
    content: '';
    position: absolute;
    inset: 0;
    background: var(--amber);
    clip-path: polygon(
      0 5%,
      8% 9%,
      18% 20%,
      27% 48%,
      39% 67%,
      52% 75%,
      67% 80%,
      82% 84%,
      100% 87%,
      100% 100%,
      0 100%
    );
    opacity: 0.45;
  }
  .detail-plot-3::after {
    content: '';
    position: absolute;
    left: 28%;
    top: 47%;
    bottom: 0;
    border-left: 1px dashed var(--amber);
  }
  .detail-footer {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    height: 4rem;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    border-top: 1px solid var(--line);
  }
  .detail-footer span {
    display: grid;
    align-content: center;
    gap: 0.25rem;
    padding-left: 1rem;
    border-right: 1px solid var(--line);
    color: #6c7a8a;
    font:
      0.5rem IBM Plex Mono,
      monospace;
  }
  .detail-footer b {
    color: #3f4d5e;
    font-size: 0.44rem;
  }
  .detail-inspector {
    padding: 1.5rem;
    border-left: 1px solid var(--line);
    color: #667587;
    font:
      0.53rem IBM Plex Mono,
      monospace;
  }
  .detail-inspector > span {
    display: block;
    margin-bottom: 2.5rem;
    color: #91a0ad;
  }
  .detail-inspector label {
    margin: 1.4rem 0;
  }
  .detail-inspector label i {
    display: block;
    width: 100%;
    height: 2px;
    margin-top: 0.65rem;
    background: linear-gradient(90deg, var(--blue) var(--v), #1a2330 var(--v));
  }
  .detail-inspector div {
    margin-top: 3rem;
    padding-top: 1rem;
    border-top: 1px solid var(--line);
  }
  .detail-inspector p {
    color: #68778a;
    font:
      400 0.7rem/1.6 Manrope,
      sans-serif;
  }
  .capability-section {
    padding-block: 10rem;
  }
  .capability-grid {
    display: grid;
    grid-template-columns: 0.8fr 1.2fr;
    gap: 9vw;
  }
  .capability-intro {
    position: sticky;
    top: 9rem;
    align-self: start;
  }
  .capability-intro h2 {
    margin: 1.5rem 0;
    font:
      500 clamp(2.8rem, 4vw, 4.8rem)/0.95 Space Grotesk,
      sans-serif;
    letter-spacing: -0.06em;
  }
  .capability-intro h2 em {
    color: var(--blue);
    font-style: normal;
  }
  .capability-intro > p {
    color: #7f8d9d;
  }
  .capability-intro .text-link {
    margin-top: 1.5rem;
  }
  .capability-list > div {
    padding: 2rem 0 3rem;
    border-top: 1px solid var(--line);
  }
  .capability-list > div > span {
    color: #637184;
    font:
      0.57rem IBM Plex Mono,
      monospace;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }
  .capability-list ul {
    margin: 2rem 0 0;
    padding: 0;
    list-style: none;
  }
  .capability-list li {
    display: flex;
    gap: 1rem;
    padding: 0.75rem 0;
    border-bottom: 1px solid rgba(184, 218, 230, 0.08);
    color: #a5b1bd;
  }
  .capability-list li i {
    width: 0.35rem;
    height: 0.35rem;
    margin-top: 0.65rem;
    flex: none;
    background: var(--blue);
    transform: rotate(45deg);
  }
  .capability-list p {
    color: #8190a0;
  }
  .next-product {
    padding-block: 5rem !important;
    background: var(--paper);
    color: var(--ink);
  }
  .next-product .shell {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .next-product span {
    font:
      0.6rem IBM Plex Mono,
      monospace;
    text-transform: uppercase;
  }
  .next-product a {
    display: flex;
    gap: 3rem;
    font: 500 clamp(1.2rem, 2vw, 2rem) Space Grotesk;
  }
  @media (max-width: 900px) {
    .product-hero-grid {
      grid-template-columns: 1fr;
    }
    .product-hero-signal {
      display: none;
    }
    .product-detail-interface {
      height: 40rem;
      grid-template-columns: 6rem 1fr;
    }
    .detail-inspector {
      display: none;
    }
    .capability-grid {
      grid-template-columns: 1fr;
    }
    .capability-intro {
      position: static;
    }
    .product-hero-copy h1 {
      font-size: clamp(3.5rem, 13vw, 6rem);
    }
  }
  @media (max-width: 560px) {
    .product-hero {
      min-height: auto;
    }
    .product-hero-copy {
      padding-block: 5rem;
    }
    .product-hero-meta {
      margin-bottom: 4rem;
    }
    .product-detail-interface {
      height: 31rem;
      grid-template-columns: 1fr;
    }
    .detail-sidebar {
      display: none;
    }
    .detail-canvas {
      padding: 1.5rem;
    }
    .detail-plot {
      left: 1.5rem;
      right: 1.5rem;
      top: 5rem;
    }
    .detail-footer span:nth-child(n + 3) {
      display: none;
    }
    .detail-footer {
      grid-template-columns: 1fr 1fr;
    }
    .interface-label span:last-child {
      display: none;
    }
    .next-product .shell {
      display: grid;
      gap: 1.5rem;
    }
    .next-product a {
      font-size: 1.4rem;
    }
  }
</style>
