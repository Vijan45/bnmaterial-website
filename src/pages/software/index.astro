---
import Base from '../../layouts/Base.astro';
import { products } from '../../config/site';
---

<Base
  title="Scientific Software"
  description="Explore BN Material scientific software for spectroscopy, microscopy image analysis, and thermal analysis."
>
  <section class="page-hero">
    <div class="shell page-hero-inner">
      <div class="page-hero-copy" data-reveal>
        <p class="eyebrow">Scientific software / 03 systems</p>
        <h1>Purpose-built tools for materials data.</h1>
        <p>
          Software environments designed around traceable laboratory workflows, meaningful controls,
          reproducible analysis, and publication-grade scientific output.
        </p>
      </div>
      <aside class="page-hero-aside" data-reveal>
        <span>Software philosophy</span>
        <strong>Data → insight</strong>
        <p>
          Analysis controls remain visible; conceptual graphics never masquerade as measured
          results.
        </p>
      </aside>
    </div>
  </section>

  <section class="page-section">
    <div class="shell catalogue-grid">
      {
        products.map((product, index) => (
          <a
            class:list={['catalogue-row', `accent-${product.accent}`]}
            href={`/software/${product.slug}`}
            data-reveal
          >
            <span>0{index + 1}</span>
            <div class="catalogue-copy">
              <small>{product.category}</small>
              <h2>{product.name}</h2>
              <p>{product.summary}</p>
            </div>
            <div class="catalogue-status">
              <>
                <span>{product.status}</span>
                <b>↗</b>
              </>
            </div>
            <div class="catalogue-graphic" aria-hidden="true" />
          </a>
        ))
      }
    </div>
  </section>
</Base>
